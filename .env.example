# Copy to .env.local and fill in from Supabase → Project Settings → API.
# These NEXT_PUBLIC_* vars are inlined into the browser bundle; that's fine —
# row-level security in Postgres controls data access, not key secrecy.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Dev-only: shared password for the /dev-login test-user switcher. Set it on
# the +pintrdevN test users in the Supabase dashboard and here. Never set in
# production (the dev-login page 404s when NODE_ENV !== "development").
DEV_LOGIN_PASSWORD=
