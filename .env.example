# Copy to .env.local and fill in from Supabase → Project Settings → API.
# These NEXT_PUBLIC_* vars are inlined into the browser bundle; that's fine —
# row-level security in Postgres controls data access, not key secrecy.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Dev-only: shared password for the /dev-login test-user switcher. Never set in
# production (the dev-login page 404s when NODE_ENV !== "development").
DEV_LOGIN_PASSWORD=

# Dev-only: needed ONLY by `npm run seed:dev` (which creates the +pintrdevN
# test users via the admin API). Supabase → Settings → API → service_role.
# SECRET — bypasses RLS. Never commit it, never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
